# TACTI-BALL PRO — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos clés

# Clés Groq (obtenez gratuitement sur https://console.groq.com)
GROQ_API_KEY=gsk_votre_cle_groq_principale_ici
GROQ_API_KEY_2=gsk_votre_cle_groq_secondaire_ici

# URL du backend (pour le keep-alive sur Render)
